# DataForge API - Environment Variables
# Copy this to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# RapidAPI (set after publishing)
RAPIDAPI_PROXY_SECRET=

# Optional: MaxMind GeoIP2 database path
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
